APP__LOG_LEVEL=debug
APP__NOTIFIER_SLEEP=300
APP__CURRENCIES=[{"ticker": "bitcoin","increment": 3000}, {"ticker": "ethereum","increment": 500}]
APP__TELEGRAM_API_KEY=<key>
APP__TELEGRAM_CHAT_IDS=<id>
APP__TELEGRAM_GET_UPDATES=false
# Quiet Mode - Suppress notifications between start_hour and end_hour (0-23)
APP__QUIET_MODE_ENABLED=false
APP__QUIET_MODE_START_HOUR=0
APP__QUIET_MODE_END_HOUR=6
